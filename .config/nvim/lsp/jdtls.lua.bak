local M = {}

local mason_path = vim.fn.stdpath("data") .. "/mason"
local jdtls_bin = mason_path .. "/packages/jdtls/bin/jdtls"
local jdtls_path = mason_path .. "/jdtls"
-- 查找主要的 launcher jar (注意版本号可能是动态的)
local launcher_jar = vim.fn.glob(jdtls_path .. "/plugins/org.eclipse.equinox.launcher_1.7.100.v20251111-0406.jar")

-- 查找对应的平台配置 (Arch Linux 使用 linux)
local config_path = jdtls_path .. "/config_linux"

-- bundles 逻辑 (确保它是扁平列表)
local bundles = {}

-- 获取调试插件 (确保返回的是列表)
local debug_jar = vim.fn.glob(
	mason_path .. "/packages/java-debug-adapter/extension/server/com.microsoft.java.debug.plugin-*.jar",
	true
)
if debug_jar ~= "" then
	table.insert(bundles, debug_jar)
end

-- 获取测试插件 (处理多文件情况)
-- local test_jars = vim.fn.glob(mason_path .. "/packages/java-test/extension/server/*.jar", true)
-- if test_jars ~= "" then
-- 	-- split 确保如果是多个 jar，会被拆分成列表元素
-- 	vim.list_extend(bundles, vim.split(test_jars, "\n"))
-- end

function M.find_root()
	local markers = { "mvnw", "gradlew", ".git", "pom.xml", "build.gradle" }
	for _, marker in ipairs(markers) do
		local path = vim.fn.finddir(marker, ".;")
		if path ~= "" then
			return vim.fn.fnamemodify(path, ":p:h")
		end
	end
	return vim.fn.getcwd()
end

function M.start()
	local root_dir = M.find_root()
	local project_name = vim.fn.fnamemodify(root_dir, ":p:h:t")
	workspace_dir = vim.fn.stdpath("cache") .. "/jdtls/" .. project_name
end

M.start()

local java_home = "/home/xi/.version-fox/sdks/java/"
M.cmd = {
	java_home .. "/bin/java", -- 直接调用系统 java
	"-Declipse.application=org.eclipse.jdt.ls.core.id1",
	"-Dosgi.bundles.defaultStartLevel=4",
	"-Declipse.product=org.eclipse.jdt.ls.core.product",
	"-Dlog.level=ALL",
	"-Djava.home=" .. java_home,
	"-Xmx1G",
	"--add-modules=ALL-SYSTEM",
	"--add-opens",
	"java.base/java.util=ALL-UNNAMED",
	"--add-opens",
	"java.base/java.lang=ALL-UNNAMED",

	-- 核心 Jar 包路径
	"-jar",
	launcher_jar,
	-- 平台配置路径
	"-configuration",
	config_path,
	-- 数据目录 (你之前的变量)
	"-data",
	workspace_dir,
}
-- M.cmd = {
-- 	jdtls_bin,
-- 	"-data",
-- 	workspace_dir,
-- 	"--add-modules=ALL-SYSTEM",
-- }
M.init_options = {
	--bundles = bundles,
	settings = {
		java = {
			configuration = {
				runtimes = {
					{
						name = "JavaSE-21",
						path = "/home/xi/.version-fox/sdks/java/",
						default = true,
					},
				},
			},
		},
	},
}
M.on_attach = function(client, bufnr)
	-- 0.11.x 建议加上一个延迟，给 LSP 一点初始化扩展的时间
	vim.defer_fn(function()
		local ok, jdtls = pcall(require, "jdtls")
		if ok then
			jdtls.setup_dap({ hotcodereplace = "auto" })
			-- 扫描 Main 方法
			require("jdtls.dap").setup_dap_main_class_configs()
		end
	end, 200) -- 延迟 200ms
end
M.filetypes = { "java" }
M.root_markers = {
	{ "mvnw", "gradlew", "settings.gradle", "settings.gradle.kts", ".git" },
	{ "build.xml", "pom.xml", "build.gradle", "build.gradle.kts" },
}

return M
