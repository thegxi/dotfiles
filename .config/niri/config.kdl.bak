include "animations.kdl"
include "environment.kdl"
include "input.kdl"
include "keybindings.kdl"
include "layout.kdl"
include "outputs.kdl"
include "rule.kdl"
include "spawn.kdl"

// 光标配置
cursor {
  // 主题，存放路径在~/.local/share/icons
  xcursor-theme "breeze_cursors"
  // 大小
  xcursor-size 30
  // 闲置多少毫秒自动隐藏光标
  hide-after-inactive-ms 15000
}

